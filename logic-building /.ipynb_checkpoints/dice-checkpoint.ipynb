    "def main():\n",
    "    number = int(input(\"Type the number (1-6):\"))\n",
    "    print(dice(number))\n",
    "\n",
    "def dice(number):\n",
    "    return f\"Number on the opposite side of the cube is {7 - number}\"\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    main()\n"
   ]
